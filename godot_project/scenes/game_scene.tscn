; ============================================================
; 连接信号 (节点属性绑定)
; ============================================================
[connection signal="pressed" from="UILayer/PauseMenuManager/PauseMainPanel/VBoxContainer/ResumeButton" to="UILayer/PauseMenuManager" method="resume_game"]
[connection signal="pressed" from="UILayer/PauseMenuManager/PauseMainPanel/VBoxContainer/SettingsButton" to="UILayer/PauseMenuManager" method="toggle_settings"]
[connection signal="pressed" from="UILayer/PauseMenuManager/PauseMainPanel/VBoxContainer/ReturnToMenuButton" to="UILayer/PauseMenuManager" method="return_to_main_menu"]
[connection signal="pressed" from="UILayer/PauseMenuManager/PauseMainPanel/VBoxContainer/QuitButton" to="UILayer/PauseMenuManager" method="quit_game"]
[connection signal="pressed" from="UILayer/PauseMenuManager/SettingsPanel/CloseSettingsButton" to="UILayer/PauseMenuManager" method="close_settings"]
