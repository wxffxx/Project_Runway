; --- 天空 & 环境 ---
[sub_resource type="ProceduralSkyMaterial" id="SkyMat_1"]
sky_top_color = Color(0.35, 0.55, 0.9, 1)
sky_horizon_color = Color(0.65, 0.75, 0.9, 1)
ground_bottom_color = Color(0.15, 0.18, 0.12, 1)
